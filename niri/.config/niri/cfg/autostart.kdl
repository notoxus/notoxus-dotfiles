// ────────────── Startup Applications ──────────────
// https://github.com/YaLTeR/niri/wiki/Configuration:-Miscellaneous#spawn-sh-at-startup

    spawn-sh-at-startup "qs -c noctalia-shell"
    spawn-sh-at-startup "fcitx5 -d"
    spawn-at-startup "/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1"
    spawn-at-startup "gnome-keyring-daemon" "--start" "--components=secrets"

    // Dark mode: GTK4/libadwaita apps and the xdg portal read color-scheme
    // from gsettings (dconf), which is machine-local binary state we don't
    // track — re-apply it every login so fresh machines get dark mode too.
    // (GTK3 theme itself is already pinned in gtk-3.0/settings.ini.)
    spawn-sh-at-startup "gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'"
